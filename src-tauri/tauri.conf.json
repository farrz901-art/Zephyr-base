{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zephyr Base",
  "version": "0.1.0",
  "identifier": "art.farrz901.zephyrbase",
  "build": {
    "beforeDevCommand": "npm --prefix ../ui run build",
    "beforeBuildCommand": "npm --prefix ../ui run build",
    "frontendDist": "../ui/dist",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zephyr Base",
        "width": 1280,
        "height": 800,
        "visible": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
